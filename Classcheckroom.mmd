---
config:
  layout: elk
---
classDiagram
direction TB

class System {
    + startRoomInspection(booking_id : String)
    + confirmInspectionComplete(booking_id : String)
    + addDamage(booking_id : String, damage_id : String)
}

class Booking {
    - booking_id : String
    - status : String
    - residencebooking_list : List~Residencebooking~
    - damage_list : List~DamageItem~
    + get_booking_item(booking_id : String)
    + update_status(status : String)
    + add_damage(damage : DamageItem)
}

class Residencebooking {
    - residence_booking_id : String
    - status : String
    - room_id : String
    + get_detail() 
    + update_status(status : String)
}

class Room {
    - room_id : String
    - status : String
    + update_status(status : String)
}

class DamageItem {
    - damage_id : String
    - description : String
    - price : float
}

%% ---------------- Relationships ----------------

System --> Booking

Booking "1" *-- "1..*" Residencebooking
Booking "1" *-- "0..*" DamageItem
Residencebooking "1" --> "1" Room